# ============================================================
# Data Quality Intelligence Platform — Environment Variables
# Copy to .env and fill in ANTHROPIC_API_KEY before starting.
# ============================================================

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Chroma vector database
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_DATA_PATH=/data/chroma

# MCP server URLs (container-to-container)
MCP_GX_URL=http://mcp-gx:8081/mcp
MCP_MC_URL=http://mcp-mc:8082/mcp
MCP_CUSTOM_URL=http://mcp-custom:8083/mcp
GX_MCP_TOKEN=

# SQLite paths
SQLITE_PATH=/data/sqlite/checkpoints.db
DECISIONS_DB_PATH=/data/sqlite/decisions.db

# Logging
LOG_LEVEL=INFO

# Cost tracking
COST_TRACKING_ENABLED=true
COST_ALERT_THRESHOLD=5.00
MAX_REQUESTS_PER_MINUTE=60

# Demo UI
API_URL=http://app:8000

# Demo data mount point
DEMO_DATA_DIR=/demo-data

# Memory retention
MEMORY_RETENTION_DAYS=90

# ============================================================
# Dependency versions (Docker build args)
# Edit here to upgrade a package, then re-run:
#   pip download --dest docker-wheels/ --extra-index-url https://download.pytorch.org/whl/cpu \
#     torch==${TORCH_VERSION} ... (all packages below)
#   docker compose build
# ============================================================
TORCH_VERSION=2.10.0
SENTENCE_TRANSFORMERS_VERSION=5.2.3
LANGGRAPH_VERSION=0.2.55
LANGGRAPH_CHECKPOINT_VERSION=2.1.2
LANGGRAPH_CHECKPOINT_SQLITE_VERSION=2.0.11
LANGCHAIN_CORE_VERSION=0.3.83
LANGCHAIN_VERSION=0.3.27
LANGCHAIN_ANTHROPIC_VERSION=0.3.4
LANGCHAIN_CHROMA_VERSION=0.2.6
LANGCHAIN_COMMUNITY_VERSION=0.3.31
LLAMA_INDEX_CORE_VERSION=0.14.15
LLAMA_INDEX_EMBEDDINGS_HF_VERSION=0.6.1
CHROMADB_VERSION=1.5.2
RANK_BM25_VERSION=0.2.2
FASTMCP_VERSION=3.1.0
FASTAPI_VERSION=0.135.1
UVICORN_VERSION=0.41.0
HTTPX_VERSION=0.28.1
PYDANTIC_VERSION=2.12.5
TENACITY_VERSION=9.1.4
STREAMLIT_VERSION=1.55.0
PYTHON_DOTENV_VERSION=1.2.2
GREAT_EXPECTATIONS_VERSION=1.13.0
PANDAS_VERSION=2.3.3
